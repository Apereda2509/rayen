# ============================================================
# RAYEN — Variables de entorno
# Copia este archivo como .env.local y completa los valores
# NUNCA subas .env.local a git
# ============================================================

# ── Base de datos (Supabase o PostgreSQL propio) ─────────────
DATABASE_URL=postgresql://usuario:password@host:5432/rayen

# ── Mapbox (mapa interactivo) ────────────────────────────────
# Obtener en: https://account.mapbox.com/access-tokens/
# Token público — se puede exponer en el frontend
NEXT_PUBLIC_MAPBOX_TOKEN=pk.xxxxxxxxxxxxxxxxxxxxxxxx

# ── Supabase (auth + storage) ────────────────────────────────
# Obtener en: https://supabase.com/dashboard/project/[id]/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxxxxxxxxx

# ── NextAuth (autenticación) ─────────────────────────────────
# Generar con: openssl rand -base64 32
NEXTAUTH_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NEXTAUTH_URL=http://localhost:3000

# ── Hero video (página de inicio) ────────────────────────────
# URL pública de un video MP4 para el fondo del hero (Cloudinary, CDN, etc.)
# Ejemplo: https://res.cloudinary.com/rayen/video/upload/hero-chile.mp4
NEXT_PUBLIC_HERO_VIDEO_URL=

# ── Cloudinary (imágenes) ────────────────────────────────────
# Obtener en: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=rayen
CLOUDINARY_API_KEY=xxxxxxxxxxxxxxx
CLOUDINARY_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── APIs externas (opcionales para sincronización) ───────────
# GBIF — no requiere auth para queries básicas
# GBIF_API_KEY=

# iNaturalist — para cargar avistamientos
# INATURALIST_API_KEY=

# UICN Red List — solicitar en https://apiv3.iucnredlist.org
# UICN_API_TOKEN=

# eBird — solicitar en https://ebird.org/api/keygen
# EBIRD_API_KEY=
